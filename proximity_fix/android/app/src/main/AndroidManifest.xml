<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.example.proximity_fix">

    <!-- ============================================ -->
    <!-- PERMISSÕES OBRIGATÓRIAS PARA O APP FUNCIONAR -->
    <!-- ============================================ -->
    
    <!-- Permite manter a tela ligada (WakeLock) -->
    <uses-permission android:name="android.permission.WAKE_LOCK" />
    
    <!-- Permite executar serviço em primeiro plano (Foreground Service) -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    
    <!-- Permite usar Foreground Service para propósito especial (Android 14+) -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_SPECIAL_USE" />
    
    <!-- Permite mostrar notificações (necessário para Android 13+) -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    
    <!-- Permite iniciar o serviço automaticamente quando o dispositivo liga -->
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />
    
    <!-- Permite vibrar o dispositivo (feedback tátil) -->
    <uses-permission android:name="android.permission.VIBRATE" />
    
    <!-- Permite ignorar otimizações de bateria para o serviço -->
    <uses-permission android:name="android.permission.REQUEST_IGNORE_BATTERY_OPTIMIZATIONS" />
    
    <!-- Declara que o app usa o sensor de proximidade -->
    <uses-feature android:name="android.hardware.sensor.proximity" android:required="true" />

    <application
        android:label="Proximity Fix"
        android:name="${applicationName}"
        android:icon="@mipmap/ic_launcher"
        android:enableOnBackInvokedCallback="true"
        android:allowBackup="true"
        android:fullBackupOnly="true">

        <!-- ============================================ -->
        <!-- ACTIVIDADE PRINCIPAL (MAIN)                  -->
        <!-- ============================================ -->
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTop"
            android:theme="@style/LaunchTheme"
            android:configChanges="orientation|keyboardHidden|keyboard|screenSize|smallestScreenSize|locale|layoutDirection|fontScale|screenLayout|density|uiMode"
            android:hardwareAccelerated="true"
            android:windowSoftInputMode="adjustResize"
            android:showWhenLocked="true"
            android:turnScreenOn="true">

            <!-- Intent Filter para ser o launcher do app -->
            <intent-filter>
                <action android:name="android.intent.action.MAIN"/>
                <category android:name="android.intent.category.LAUNCHER"/>
            </intent-filter>
        </activity>

        <!-- ============================================ -->
        <!-- FOREGROUND SERVICE PARA MANTER PROTEÇÃO      -->
        <!-- ============================================ -->
        <!-- 
            Este serviço roda em segundo plano mantendo a tela ligada
            e monitorando o sensor de proximidade continuamente.
            A propriedade "specialUse" é necessária para Android 14+.
        -->
        <service
            android:name="com.pravera.flutter_foreground_task.service.ForegroundService"
            android:foregroundServiceType="specialUse"
            android:exported="false"
            android:stopWithTask="false"
            android:enabled="true">
            
            <!-- Propriedade especial para Android 14+ -->
            <property
                android:name="android.app.PROPERTY_SPECIAL_USE_FGS_SUBTYPE"
                android:value="Manter tela ligada durante uso do sensor de proximidade"/>
        </service>

        <!-- ============================================ -->
        <!-- RECEIVER PARA INICIAR APÓS BOOT              -->
        <!-- ============================================ -->
        <!-- 
            Este BroadcastReceiver escuta o evento de boot completo
            e inicia automaticamente o serviço se configurado pelo usuário.
        -->
        <receiver
            android:name="com.pravera.flutter_foreground_task.service.BootReceiver"
            android:enabled="true"
            android:exported="true"
            android:permission="android.permission.RECEIVE_BOOT_COMPLETED">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
                <action android:name="android.intent.action.QUICKBOOT_POWERON" />
                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>
        </receiver>

        <!-- ============================================ -->
        <!-- METADADOS DO FLUTTER                         -->
        <!-- ============================================ -->
        <meta-data
            android:name="flutterEmbedding"
            android:value="2" />

    </application>

    <!-- Queries para compatibilidade com Android 11+ -->
    <queries>
        <intent>
            <action android:name="android.intent.action.PROCESS_TEXT"/>
            <data android:mimeType="text/plain"/>
        </intent>
    </queries>

</manifest>
